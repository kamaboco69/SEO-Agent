generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model Project {
  id          String   @id @default(cuid())
  name        String
  domain      String?
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  keywords    TrackedKeyword[]
  articles    Article[]
  handoffs    AnalystHandoff[]
  media       Media[]
}

model AuthUser {
  id                    String   @id @default(cuid())
  email                 String   @unique
  name                  String?
  image                 String?
  passwordHash          String?
  aiCompanyLinkDisabled Boolean  @default(false)
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  accounts  AuthAccount[]
  sessions  AuthSession[]
  aiCompany AiCompanyProfile?
}

model AuthAccount {
  id                String   @id @default(cuid())
  userId            String
  user              AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  provider          String
  providerAccountId String
  email             String?
  accessToken       String?
  refreshToken      String?
  expiresAt         DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  @@unique([provider, providerAccountId])
}

model AuthSession {
  id           String   @id @default(cuid())
  userId       String
  user         AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken String   @unique
  expiresAt    DateTime
  createdAt    DateTime @default(now())
}

model AiCompanyProfile {
  id                String   @id @default(cuid())
  userId            String   @unique
  user              AuthUser @relation(fields: [userId], references: [id], onDelete: Cascade)
  aiCompanyId       String   @unique
  displayName       String?
  email             String?
  defaultDomain     String?
  defaultProjectName String?
  defaultObjective  String?
  defaultContext    String?
  settings          Json     @default("{}")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model TrackedKeyword {
  id         String   @id @default(cuid())
  keyword    String
  targetUrl  String?
  projectId  String?
  project    Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  rankings   KeywordRanking[]
}

model KeywordRanking {
  id         String         @id @default(cuid())
  keywordId  String
  keyword    TrackedKeyword @relation(fields: [keywordId], references: [id], onDelete: Cascade)
  position   Int
  url        String?
  checkedAt  DateTime       @default(now())
}

model Article {
  id           String   @id @default(cuid())
  title        String
  content      String   @default("")
  targetKw     String?
  metaTitle    String?
  metaDesc     String?
  seoScore     Int?
  wordCount    Int?
  projectId    String?
  project      Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model AnalystHandoff {
  id             String   @id @default(cuid())
  projectId      String?
  project        Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  title          String
  objective      String
  targetDomain   String?
  status         String   @default("draft")
  priority       String   @default("normal")
  payload        Json
  analystNotes   String?
  recommendation String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Media {
  id                String   @id @default(cuid())
  projectId         String?
  project           Project? @relation(fields: [projectId], references: [id], onDelete: SetNull)
  name              String
  domain            String
  description       String?
  audience          String?
  tone              String?
  mainCategories    Json     @default("[]")
  aiCompanyMediaId  String?
  syncStatus        String   @default("pending")
  syncMessage       String?
  wpUrl             String?
  wpSecret          String?
  wpConnectedAt     DateTime?
  gscProperty       String?
  ga4PropertyId     String?
  analyticsConnectedAt DateTime?
  scheduleEnabled     Boolean   @default(false)
  schedulePerMonth    Int       @default(2)
  scheduleWordCount   Int?
  scheduleInstruction String?
  scheduleOwnerEmail  String?
  scheduleLastRunAt   DateTime?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  workflows         ContentWorkflow[]
  plans             ScheduledArticle[]
}

// 自動スケジュールの執筆予定（カレンダー表示・AI秘書のGoogleカレンダー連携の単位）。
// テーマは予定作成時にAIが提案し、plannedDate（JSTの日付）が来たらcronが執筆を開始する。
model ScheduledArticle {
  id              String   @id @default(cuid())
  mediaId         String
  media           Media    @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  plannedDate     DateTime // JSTの日付（そのJST日の00:00をUTCで保持）
  theme           String
  wordCount       Int?     // この予定の目標文字数（null=メディアのスケジュール設定に従う）
  status          String   @default("planned") // planned / generating / done / failed
  source          String   @default("auto")    // auto=自動計画 / manual=ユーザーが日付指定（自動調整で削除されない）
  workflowId      String?
  calendarEventId String?  // AI秘書（AICompany）のGoogleカレンダーのイベントID
  calendarUrl     String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([mediaId, plannedDate])
}

model ContentWorkflow {
  id                String   @id @default(cuid())
  mediaId           String?
  media             Media?   @relation(fields: [mediaId], references: [id], onDelete: Cascade)
  clientName        String?
  clientSite        String?
  origin            String   @default("manual")
  ownerEmail        String?  // 実行を開始したユーザー（サーバー側自動再開時のトークン計上先）
  instruction       String
  targetTheme       String?
  targetWordCount   Int?
  status            String   @default("draft")
  currentStep       String   @default("media_analysis")
  automationMode    String   @default("approval_required")
  selectedArticle   String?
  approved1         Boolean  @default(false)
  approved2         Boolean  @default(false)
  finalArticleTitle String?
  finalArticle      String?
  wpPostId          Int?
  wpEditLink        String?
  wpViewLink        String?
  wpPublished       Boolean  @default(false)
  finalHtml         String?
  imagesGenerated   Boolean  @default(false)
  gdocId            String?
  gdocUrl           String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  steps             WorkflowStep[]
}

// 汎用キャッシュ。高コストな外部取得（GSC/GA4分析・WP全記事コンテキスト・契約チェック等）の結果を保持する。
model CacheEntry {
  key       String   @id
  payload   Json
  expiresAt DateTime
  updatedAt DateTime @updatedAt
}

model WorkflowStep {
  id             String          @id @default(cuid())
  workflowId     String
  workflow       ContentWorkflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)
  key            String
  label          String
  status         String          @default("pending")
  input          Json            @default("{}")
  output         Json            @default("{}")
  revisionNote   String?
  approvedAt     DateTime?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([workflowId, key])
}
